<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN" "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.kde.kdeconnect.device.remotesystemvolume">
    <property name="sinks" type="ay" access="read"/>
    <property name="deviceId" type="s" access="read"/>
    <signal name="sinksChanged">
    </signal>
    <signal name="volumeChanged">
      <arg name="name" type="s" direction="out"/>
      <arg name="volume" type="i" direction="out"/>
    </signal>
    <signal name="mutedChanged">
      <arg name="name" type="s" direction="out"/>
      <arg name="muted" type="b" direction="out"/>
    </signal>
    <method name="sendVolume">
      <arg name="name" type="s" direction="in"/>
      <arg name="volume" type="i" direction="in"/>
    </method>
    <method name="sendMuted">
      <arg name="name" type="s" direction="in"/>
      <arg name="muted" type="b" direction="in"/>
    </method>
  </interface>
</node>
